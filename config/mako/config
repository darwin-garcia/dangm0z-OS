# Posición y tamaño

layer=overlay
anchor=top-right
max-icon-size=32

width=400
height=110
margin=10
padding=15

# Estilo

text-color=#e6e6e6
border-color=#e65c5c
background-color=#26262650
progress-color=#66cc66

border-size=2
border-radius=10
outer-margin=10

font=JetBrainsMono Nerd Font 11

# Comportamiento

default-timeout=5000
ignore-timeout=0
max-visible=5

# Urgencia crítica (distinto color)

[urgency=critical]
background-color=#f38ba8
text-color=#1e1e2e
border-color=#f38ba8

[app-name=Spotify]
invisible=1

[mode=do-not-disturb]
invisible=true

[mode=do-not-disturb app-name=notify-send]
invisible=false